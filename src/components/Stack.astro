---
import { stackRows } from '../data/site';
---

<section class="wrap" id="stack">
  <div class="sec-head reveal"><h2>Stack</h2><span class="tag">05 — With what</span></div>
  <div class="stack-rows reveal">
    {stackRows.map((row) => (
      <div class="stack-row">
        <span class="k">{row.k}</span>
        <span class="v">
          {row.v.map((item, i) => (
            <Fragment>{i > 0 && <em>·</em>}{item}</Fragment>
          ))}
        </span>
      </div>
    ))}
  </div>
</section>

<style>
  .stack-rows{ border-top:1px solid var(--line); }
  .stack-row{ display:grid; grid-template-columns:210px 1fr; gap:1.2rem; padding:1.15rem 0; border-bottom:1px solid var(--line); align-items:baseline; }
  .stack-row .k{ font-family:var(--mono); font-size:.72rem; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-3); }
  .stack-row .v{ font-size:.94rem; color:var(--ink); line-height:1.7; }
  .stack-row .v em{ font-style:normal; color:var(--ink-3); padding:0 .35rem; }
  @media (max-width:640px){ .stack-row{ grid-template-columns:1fr; gap:.3rem; } }
</style>
