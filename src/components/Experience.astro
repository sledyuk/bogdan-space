---
import { experience } from '../data/site';
---

<section class="wrap" id="experience">
  <div class="sec-head reveal"><h2>Experience</h2><span class="tag">04 — Where</span></div>
  <ol class="xp reveal">
    {experience.map((e) => (
      <li class="xp-row">
        <span class="yr">{e.years}</span>
        <div class="who"><h3>{e.org}</h3><p class="rl">{e.role}</p></div>
        <p class="what">{e.summary}</p>
        <span class="arw" aria-hidden="true">→</span>
      </li>
    ))}
  </ol>
</section>

<style>
  .xp{ border-top:1px solid var(--line); }
  .xp-row{ display:grid; grid-template-columns:120px 1.1fr 1.6fr auto; gap:1.2rem; align-items:baseline;
    padding:1.35rem 0; border-bottom:1px solid var(--line); transition:padding-left .25s var(--ease); position:relative; }
  .xp-row::before{ content:""; position:absolute; left:0; top:0; bottom:-1px; width:0; background:var(--ink); transition:width .25s var(--ease); }
  .xp-row:hover{ padding-left:1.1rem; }
  .xp-row:hover::before{ width:3px; }
  .xp-row .yr{ font-family:var(--mono); font-size:.76rem; color:var(--ink-3); }
  .xp-row .who h3{ font-size:1.02rem; line-height:1.3; }
  .xp-row .who .rl{ font-size:.8rem; color:var(--accent); font-weight:500; margin-top:.1rem; }
  .xp-row .what{ font-size:.9rem; color:var(--ink-2); line-height:1.55; }
  .xp-row .arw{ font-family:var(--mono); color:var(--ink-3); transition:transform .25s var(--ease), color .2s; }
  .xp-row:hover .arw{ transform:translateX(4px); color:var(--ink); }
  @media (max-width:820px){
    .xp-row{ grid-template-columns:1fr; gap:.35rem; }
    .xp-row .arw{ display:none; }
  }
</style>
