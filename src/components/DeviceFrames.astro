---
import fs from 'node:fs';
import Cover from './Cover.astro';

const hasWeb = fs.existsSync('public/assets/work/daysync-web.webp');
const hasMobile = fs.existsSync('public/assets/work/daysync-mobile.webp');
const hasShots = hasWeb && hasMobile;
---

{hasShots ? (
  <div class="frames">
    <img class="web" src="/assets/work/daysync-web.webp" alt="DaySync web dashboard" loading="lazy" width="1280" height="727" />
    <img class="mob" src="/assets/work/daysync-mobile.webp" alt="DaySync mobile app" loading="lazy" width="644" height="1400" />
  </div>
) : (
  <Cover slug="daysync" name="DaySync" />
)}

<style>
  .frames{ display:flex; align-items:flex-end; justify-content:center; gap:1.1rem; padding:1.6rem 1.6rem 0; height:100%; background:
    radial-gradient(rgba(20,20,22,.08) 1px, transparent 1px) 0 0 / 20px 20px, #F1F1EE; }
  .web{ flex:1; min-width:0; height:auto; filter:drop-shadow(0 8px 24px rgba(20,20,22,.10)); }
  .mob{ width:26%; flex:none; height:auto; filter:drop-shadow(0 8px 24px rgba(20,20,22,.12)); }
  @media (max-width:560px){ .mob{ display:none; } }
</style>
