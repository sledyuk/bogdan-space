---
import fs from 'node:fs';
import { site } from '../data/site';

const hasPortrait = fs.existsSync('public/assets/portrait.webp');
---

<section class="hero wrap" id="hero" aria-label="Introduction">
  <div class:list={['hero-grid', { 'no-portrait': !hasPortrait }]}>
    <div>
      <span class="status rise d1"><span class="dot" aria-hidden="true"></span>Open to Senior / Lead roles · Remote UTC+4</span>
      <h1 class="rise d2">{site.name}</h1>
      <p class="role rise d3">
        Senior Software Engineer &amp; Tech Lead — 12+ years shipping <b>fintech and healthcare</b> products across
        web and mobile, with an <b>AI-native, agentic</b> way of building software.
      </p>
      <div class="contact-row rise d4">
        <button class="chip chip-solid" id="copyEmail" type="button" aria-label={`Copy email address ${site.email}`}>
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
          {site.email}
          <span class="done" aria-hidden="true">Copied ✓</span>
        </button>
        <a class="chip chip-ghost" href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="chip chip-ghost" href={site.resumePath} download>Résumé (PDF)</a>
      </div>
    </div>
    {hasPortrait && (
      <div class="portrait rise d3">
        <img src="/assets/portrait.webp" alt="Portrait of Bogdan Egikov" width="440" height="490" loading="eager" />
      </div>
    )}
  </div>
</section>

<style>
  .hero{ padding-top:clamp(3.4rem, 9vh, 6.5rem); padding-bottom:clamp(2.6rem, 6vh, 4.5rem); }
  .hero-grid{ display:grid; grid-template-columns:1fr 232px; gap:clamp(1.6rem, 4vw, 3.5rem); align-items:end; }
  .hero-grid.no-portrait{ grid-template-columns:1fr; }
  .status{ display:inline-flex; align-items:center; gap:.55rem; font-family:var(--mono); font-size:.72rem; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-2); border:1px solid var(--line-2); border-radius:100px; padding:.4rem .9rem; }
  .status .dot{ width:7px; height:7px; border-radius:50%; background:var(--accent); animation:pulse 2.4s var(--ease) infinite; }
  .hero h1{ font-size:clamp(2.9rem, 7.4vw, 5.4rem); line-height:1.0; letter-spacing:-.035em; margin:1.3rem 0 .9rem; }
  .hero .role{ font-size:clamp(1.02rem, 1.6vw, 1.2rem); color:var(--ink-2); max-width:44ch; line-height:1.55; }
  .hero .role b{ color:var(--ink); font-weight:600; }
  .contact-row{ display:flex; flex-wrap:wrap; gap:.6rem; margin-top:1.8rem; }
  .chip{ display:inline-flex; align-items:center; gap:.5rem; font-size:.88rem; font-weight:500; padding:.7rem 1.15rem; border-radius:100px; border:1px solid var(--line-2); white-space:nowrap; transition:transform .18s var(--ease), background .18s, color .18s, border-color .18s; }
  .chip:hover{ transform:translateY(-2px); }
  .chip-solid{ background:var(--ink); border-color:var(--ink); color:var(--paper); }
  .chip-solid:hover{ background:var(--accent); border-color:var(--accent); }
  .chip-ghost:hover{ border-color:var(--ink); }
  .chip .ic{ width:14px; height:14px; flex:none; }
  #copyEmail{ position:relative; }
  #copyEmail .done{ position:absolute; inset:0; display:flex; align-items:center; justify-content:center; gap:.4rem; background:var(--accent); color:#fff; border-radius:100px; opacity:0; transform:scale(.92); transition:opacity .2s, transform .25s var(--ease); pointer-events:none; font-weight:500; }
  #copyEmail.copied .done{ opacity:1; transform:scale(1); }

  .portrait{ border-radius:16px; overflow:hidden; border:1px solid var(--line); aspect-ratio:1/1.12; }
  .portrait img{ width:100%; height:100%; object-fit:cover; filter:grayscale(1); transition:filter .5s var(--ease), transform .6s var(--ease); }
  .portrait:hover img{ filter:grayscale(0); transform:scale(1.03); }
  @media (max-width:760px){ .hero-grid{ grid-template-columns:1fr; align-items:start; } .portrait{ max-width:240px; order:-1; } }
  @media print{ .contact-row{ display:none !important; } .portrait img{ filter:none; } }
</style>
